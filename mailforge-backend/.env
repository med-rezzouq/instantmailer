# ── App ──────────────────────────────────────────
APP_NAME=MailForge
APP_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mailforge:mailforge_pass@db:5432/mailforge
SYNC_DATABASE_URL=postgresql+psycopg2://mailforge:mailforge_pass@db:5432/mailforge

# ── Microsoft 365 (Azure AD) ─────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/oauth/microsoft/callback

# ── Google Workspace (Gmail API) ─────────────────
# Get from https://console.cloud.google.com → APIs & Services
GOOGLE_APP_MAX_MAILBOXES=2
GOOGLE_REDIRECT_URI=http://localhost:8000/mailboxes/oauth/google/callback

# ── Redis (for rate limiting & task queue) ────────
REDIS_URL=redis://redis:6379/0

# ── Email send settings ───────────────────────────
MAX_EMAILS_PER_BATCH=500
SEND_CONCURRENCY_LIMIT=50

# ── Frontend URL (CORS) ───────────────────────────
FRONTEND_URL=https://localhost:3000

FRONTEND_URL2=https://mailforge.local.test:3000